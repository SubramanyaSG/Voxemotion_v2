# ============================================================
# VoxEmotion — Environment Variables
# Copy this file to .env for local dev (never commit .env)
# On Azure: set these in App Service → Configuration → App Settings
# ============================================================

# ── Flask ─────────────────────────────────────────────────
FLASK_SECRET_KEY=replace_with_any_random_64_char_string
AZURE_DEPLOYMENT=true

# ── App URL (update after Azure deployment) ───────────────
APP_BASE_URL=https://your-app-name.azurewebsites.net

# ── Email (optional — for password reset) ────────────────
SMTP_EMAIL=support.voxemotion@gmail.com
SMTP_APP_PASSWORD=your_gmail_app_password_here

# ── Azure Blob Storage (optional — for model files) ──────
# Only needed if you want to store model files in Azure Blob
# Get this from Azure Portal → Storage Account → Access keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_BLOB_CONTAINER=voxemotion-models

# ── Dataset (leave empty on Azure — inference only) ───────
DATASET_ROOT=
