# ============================================================
# VoxEmotion – Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ============================================================

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=replace_with_your_64_char_random_string

# Gmail App Password for password reset emails
# Setup: Google Account → Security → 2FA → App Passwords → Generate
SMTP_EMAIL=support_voxemotion@gmail.com
SMTP_APP_PASSWORD=your_16_char_gmail_app_password

# Your app's public URL (update when hosting online)
APP_BASE_URL=http://127.0.0.1:5000

# Port (default 5000)
PORT=5000
